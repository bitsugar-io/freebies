# Environment Configuration (optional for local dev)

# Environment
ENVIRONMENT=local

# AWS LocalStack
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Table Names (auto-populated by Terraform outputs)
USERS_TABLE=freebie-users-local
OFFERS_TABLE=freebie-offers-local
RULES_TABLE=freebie-rules-local
SUBSCRIPTIONS_TABLE=freebie-subscriptions-local

# SSM Parameter Store Prefix
SSM_PREFIX=/freebie/local

# SQS
NOTIFICATIONS_QUEUE=http://localhost:4566/000000000000/freebie-notifications-local

# Pinpoint (prod only)
ENABLE_PINPOINT=false
